</w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t> Tokenizer breaks HTML into tokens</w:t></w:r></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>   </w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>•</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t> Parser builds tree structure</w:t></w:r></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>   </w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>•</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t> Each element = DOM node</w:t></w:r></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>   HTML </w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>→</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t> Tokens </w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>→</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t> Nodes </w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>→</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t> DOM Tree</w:t></w:r></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="00B724A5"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>3. PARSE CSS </w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>→</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t> BUILD CSSOM TREE</w:t></w:r></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>   </w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>•</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t> Same process for CSS</w:t></w:r></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>   </w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>•</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t> Calculates computed styles for each element</w:t></w:r></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>   CSS </w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>→</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155