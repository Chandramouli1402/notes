="334155"/></w:rPr><w:t> Shorter and more RESILIENT</w:t></w:r></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>•</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t> Survives minor DOM changes</w:t></w:r></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>•</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t> What SDET professionals write</w:t></w:r></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="00B724A5"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>ALWAYS use Relative XPath!</w:t></w:r></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="00B724A5"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="00B724A5"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>Comparison:</w:t></w:r></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>Absolute: /html/body/div[2]/div[1]/div/div/form/</w:t></w:r><w:proofErr w:type="gramStart"/><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>div[</w:t></w:r><w:proofErr w:type="gramEnd"/><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>3]/div/input</w:t></w:r></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>Relative: //input[@name='password']</w:t></w:r></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="00B724A5"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>Both find the same element, but relative survives redesigns.</w:t></w:r></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="00B724A5"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>Evaluator Note: If a trainee uses absolute XPath, they haven't understood the fundamentals.</w:t></w:r></w:p><wx:pBdrGroup><wx:borders><wx:bottom wx:val="solid" wx:bdrwidth="10" wx:space="1" wx:color="E2E8F0"/></wx:borders><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="00B724A5"><w:pPr><w:pBdr><w:bottom w:val="single" w:sz="4" wx:bdrwidth="10" w:space="1" w:color="E2E8F0"/></w:pBdr></w:pPr></w:p></wx:pBdrGroup><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="240"/></w:pPr><w:r><w:rPr><w:b/><w:color w:val="1E293B"/><w:sz w:val="22"/></w:rPr><w:t>Q35. [Intermediate] Explain XPath abbreviated vs unabbreviated syntax.</w:t></w:r></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>XPath has a FULL (unabbreviated) syntax and a SHORT (abbreviated) syntax. Both do the same thing.</w:t></w:r></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="00B724A5"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>═══</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t> UNABBREVIATED (Full Axis Syntax) </w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>═══</w:t></w:r></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="00B724A5"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr><w:proofErr w:type="gramStart"/><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>child::</w:t></w:r><w:proofErr w:type="gramEnd"/><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>div                         </w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>→</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t> Direct child div</w:t></w:r></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr><w:proofErr w:type="gramStart"/><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>descendant::</w:t></w:r><w:proofErr w:type="gramEnd"/><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></