l="334155"/></w:rPr><w:t> Initial size before grow/shrink</w:t></w:r></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>  auto (default) </w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>→</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t> Use content size</w:t></w:r></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>  200px          </w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>→</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t> Start at 200px, then grow/shrink</w:t></w:r></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="00B724A5"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>flex shorthand:</w:t></w:r></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>  flex: 1          </w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>→</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t> flex-grow:1, shrink:1, basis:0</w:t></w:r></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="20" w