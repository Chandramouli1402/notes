20"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>•</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t> Very LONG and FRAGILE</w:t></w:r></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>•</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t> ANY change in page structure BREAKS it</w:t></w:r></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>•</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t> Generated by browser "Copy XPath" feature</w:t></w:r></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="00B724A5"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>NEVER use Absolute XPath in automation! </w:t></w:r></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="00B724A5"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="00B724A5"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>RELATIVE XPath </w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>—</w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="