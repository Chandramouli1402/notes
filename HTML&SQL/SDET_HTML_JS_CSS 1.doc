onts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>What changed from HTML4:</w:t></w:r></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="00B724A5"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>1. Simpler DOCTYPE:</w:t></w:r></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>   HTML4: &lt;!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.01//EN" "http://www.w3.org/TR/html4/strict.dtd"&gt;</w:t></w:r></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>   HTML5: &lt;!DOCTYPE html</w:t></w:r><w:proofErr w:type="gramStart"/><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>&gt;  </w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>←</w:t></w:r><w:proofErr w:type="gramEnd"/><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t> That's it!</w:t></w:r></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="00B724A5"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="20" w:after="20"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Consolas"/><wx:font wx:val="Consolas"/><w:color w:val="334155"/></w:rPr><w:t>2. No more plugin dependency (Flash, Silverlight)</w:t></w:r></w:p><w:p wsp:rsidR="00B724A5" wsp:rsidRDefault="002A511A"><w:pPr><w:spacing w:before="20" w:af